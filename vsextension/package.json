{
  "name": "projspec",
  "displayName": "projspec",
  "description": "projspec",
  "version": "0.0.1",
  "repository": "https://github.com/fsspec/projspec",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "projspec.showTree",
        "title": "Project Library"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "projspec",
          "title": "projspec",
          "icon": "media/search.svg"
        }
      ]
    },
    "views": {
      "projspec": [
        {
          "id": "projspec.view",
          "name": "Project Library"
        }
      ]
    },
    "menus": {}
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.109.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  }
}
