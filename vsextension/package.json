{
  "name": "projspec",
  "displayName": "projspec",
  "description": "projspec",
  "version": "0.0.1",
  "repository": "https://github.com/fsspec/projspec",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "projspec.scan",
        "title": "Projspec scan"
      },
      {
        "command": "projspec.showTree",
        "title": "Show Project Library"
      },
      {
        "command": "projspec.openProject",
        "title": "Open Project"
      },
      {
        "command": "projspec.showJson",
        "title": "Show"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "projspec-projects",
          "name": "Project Library"
        }
      ]
    },
    "menus": {
      "view/item/context": [
        {
          "command": "projspec.openProject",
          "when": "view == projspec-projects && viewItem == project",
          "group": "navigation"
        },
        {
          "command": "projspec.showJson",
          "when": "view == projspec-projects && viewItem == project",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.109.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.54.0",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
